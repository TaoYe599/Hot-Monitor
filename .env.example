# Hot Monitor 环境变量示例
# 复制为 `.env` 后，再填写你自己的配置。

# OpenRouter
# 如果你要启用 AI 真假识别和热点聚类，就需要填写。
OPENROUTER_API_KEY=

# 建议使用支持 structured outputs / JSON schema 的模型。
OPENROUTER_MODEL=openai/gpt-4.1-mini

# 可选，会作为应用信息传给 OpenRouter。
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Hot Monitor

# Twitter / X 数据源
# 如果你要通过 twitterapi.io 拉取最新内容，就需要填写。
TWITTERAPI_IO_KEY=

# Webhook 通知
# 多个 webhook 地址请用英文逗号分隔。
WEBHOOK_URLS=

# 邮件通知
# 只有你要启用 SMTP 邮件提醒时才需要填写。
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
# 多个收件邮箱请用英文逗号分隔。
EMAIL_TO=

# 浏览器推送通知
# 只有你要启用 Web Push 时才需要填写。
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:hot-monitor@example.com

# 本地服务
HOT_MONITOR_PORT=8787
HOT_MONITOR_PUBLIC_URL=http://localhost:8787

# 本地 SQLite 数据库
HOT_MONITOR_DB_PATH=file:./apps/server/data/hot-monitor.db
